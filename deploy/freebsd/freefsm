#!/bin/sh

# PROVIDE: freefsm
# REQUIRE: LOGIN postgresql
# KEYWORD: shutdown

. /etc/rc.subr

name="freefsm"
rcvar="freefsm_enable"

command="/usr/local/bin/freefsm"
pidfile="/var/run/${name}.pid"
required_files="${command}"

freefsm_config="/usr/local/etc/freefsm.conf"

freefsm_start()
{
    if [ -f "${freefsm_config}" ]; then
        . "${freefsm_config}"
        export DATABASE_URL SESSION_SECRET PORT ENV STATIC_PATH SETUP_TOKEN
    fi

    if [ ! -f /var/log/freefsm.log ]; then
        touch /var/log/freefsm.log
        chown freefsm:freefsm /var/log/freefsm.log
        chmod 644 /var/log/freefsm.log
    fi

    export freefsm_flags="-log /var/log/freefsm.log"
}

load_rc_config $name
run_rc_command "$1"