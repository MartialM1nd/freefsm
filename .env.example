# Database connection
DATABASE_URL=postgres://freefsm:password@localhost:5432/freefsm?sslmode=disable

# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-random-string

# Server
PORT=8080

# Environment (development|production)
ENV=development

# Static files path (default: ui/static)
# For production: /usr/local/share/freefsm/static
#STATIC_PATH=/usr/local/share/freefsm/static

# Log file path (default: /var/log/freefsm.log)
#LOG_PATH=/var/log/freefsm.log
